@page
@model HotelManagement.Pages.Admin.ManageRoomsModel

<div class="card">

    <div class="card-header">

        <h3 class="card-title">Manage Rooms</h3>

        <a href="/Admin/AddRoom" class="btn btn-primary float-right">
            <i class="fas fa-plus"></i> Add Room
        </a>

    </div>

    <div class="card-body">

        <input type="text" id="searchRoom" class="form-control mb-3" placeholder="Search room...">

        <table class="table table-bordered table-striped" id="roomTable">

            <thead class="thead-dark">

                <tr>
                    <th>ID</th>
                    <th>Hotel</th>
                    <th>Room Type</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th width="120">Action</th>
                </tr>

            </thead>

            <tbody>

                <tr>
                    <td>1</td>
                    <td>Hilton</td>
                    <td>Deluxe</td>
                    <td>$120</td>

                    <td>
                        <span class="badge bg-success">Available</span>
                    </td>

                    <td>

                        <button class="btn btn-warning btn-sm">
                            <i class="fas fa-edit"></i>
                        </button>

                        <button class="btn btn-danger btn-sm"
                                onclick="return confirm('Are you sure you want to delete this room?')">
                            <i class="fas fa-trash"></i>
                        </button>

                    </td>

                </tr>

                <tr>
                    <td>2</td>
                    <td>Marriott</td>
                    <td>Suite</td>
                    <td>$200</td>

                    <td>
                        <span class="badge bg-danger">Booked</span>
                    </td>

                    <td>

                        <button class="btn btn-warning btn-sm">
                            <i class="fas fa-edit"></i>
                        </button>

                        <button class="btn btn-danger btn-sm"
                                onclick="return confirm('Are you sure you want to delete this room?')">
                            <i class="fas fa-trash"></i>
                        </button>

                    </td>

                </tr>

            </tbody>

        </table>


        <!-- Pagination -->

        <div class="d-flex justify-content-end mt-3">

            <button class="btn btn-outline-secondary btn-sm me-1">Previous</button>

            <button class="btn btn-outline-primary btn-sm me-1">1</button>
            <button class="btn btn-outline-secondary btn-sm me-1">2</button>
            <button class="btn btn-outline-secondary btn-sm me-1">3</button>

            <button class="btn btn-outline-secondary btn-sm">Next</button>

        </div>

    </div>
</div>


<script>

    document.getElementById("searchRoom").addEventListener("keyup", function(){

        var value = this.value.toLowerCase();
        var rows = document.querySelectorAll("#roomTable tbody tr");

        rows.forEach(function(row){

            row.style.display = row.textContent.toLowerCase().includes(value)
            ? "" : "none";

        });

    });

</script>