@page
@model HotelManagement.Pages.Admin.ManageBookingsModel

<div class="card">

    <div class="card-header">
        <h3 class="card-title">Manage Bookings</h3>
    </div>

    <div class="card-body">

        <input type="text" id="searchBooking" class="form-control mb-3" placeholder="Search booking...">

        <table class="table table-bordered table-striped" id="bookingTable">

            <thead class="thead-dark">

                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Hotel</th>
                    <th>Room</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th width="120">Action</th>
                </tr>

            </thead>

            <tbody>

                <tr>
                    <td>1001</td>
                    <td>John</td>
                    <td>Hilton</td>
                    <td>Deluxe</td>
                    <td>12/03/2026</td>

                    <td>
                        <span class="badge bg-success">Confirmed</span>
                    </td>

                    <td>
                        <button class="btn btn-danger btn-sm">
                            Cancel
                        </button>
                    </td>

                </tr>

                <tr>
                    <td>1002</td>
                    <td>Anna</td>
                    <td>Marriott</td>
                    <td>Suite</td>
                    <td>14/03/2026</td>

                    <td>
                        <span class="badge bg-warning">Pending</span>
                    </td>

                    <td>
                        <button class="btn btn-success btn-sm">
                            Confirm
                        </button>
                    </td>

                </tr>

                <tr>
                    <td>1003</td>
                    <td>Mike</td>
                    <td>Sheraton</td>
                    <td>Standard</td>
                    <td>16/03/2026</td>

                    <td>
                        <span class="badge bg-danger">Cancelled</span>
                    </td>

                    <td>
                        <button class="btn btn-secondary btn-sm">
                            View
                        </button>
                    </td>

                </tr>

            </tbody>

        </table>


        <!-- Pagination -->

        <div class="d-flex justify-content-end mt-3">

            <button class="btn btn-outline-secondary btn-sm me-1">Previous</button>

            <button class="btn btn-outline-primary btn-sm me-1">1</button>
            <button class="btn btn-outline-secondary btn-sm me-1">2</button>
            <button class="btn btn-outline-secondary btn-sm me-1">3</button>

            <button class="btn btn-outline-secondary btn-sm">Next</button>

        </div>

    </div>
</div>


<script>

    document.getElementById("searchBooking").addEventListener("keyup", function(){

        var value = this.value.toLowerCase();
        var rows = document.querySelectorAll("#bookingTable tbody tr");

        rows.forEach(function(row){

            row.style.display = row.textContent.toLowerCase().includes(value)
            ? "" : "none";

        });

    });

</script>