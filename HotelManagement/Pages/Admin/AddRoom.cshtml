@page
@model HotelManagement.Pages.Admin.AddRoomModel
@{
    Layout = "_AdminLayout";
}

<div class="container py-5">

    <div class="card shadow-lg p-4">

        <h3 class="mb-4 text-center">Add New Room</h3>

        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success text-center">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger text-center">
                    @TempData["ErrorMessage"]
                </div>
            }

            <!-- Title -->
            <div class="mb-3">
                <label>Room Title</label>
                <input asp-for="Room.title" class="form-control" placeholder="Luxury Room">
                <span asp-validation-for="Room.title" class="text-danger"></span>
            </div>

            <!-- Location -->
            <div class="mb-3">
                <label>Location</label>
                <input asp-for="Room.room_type" class="form-control" placeholder="Ho Chi Minh City">
                <span asp-validation-for="Room.room_type" class="text-danger"></span>
            </div>

            <!-- Price -->
            <div class="mb-3">
                <label>Price</label>
                <input asp-for="Room.price" type="number" class="form-control">
                <span asp-validation-for="Room.price" class="text-danger"></span>
            </div>

            <!-- Guests -->
            <div class="mb-3">
                <label>Guests</label>
                <input asp-for="Room.guests" type="number" class="form-control">
				<span asp-validation-for="Room.guests" class="text-danger"></span>
            </div>

            <!-- Bed Type -->
            <div class="mb-3">
                <label>Bed Type</label>
                <input asp-for="Room.bed_type" class="form-control" placeholder="King-size">
				<span asp-validation-for="Room.bed_type" class="text-danger"></span>
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label>Description</label>
                <textarea asp-for="Room.description" class="form-control" rows="4"></textarea>
				<span asp-validation-for="Room.description" class="text-danger"></span>
            </div>

            <!-- Facilities -->
            <div class="mb-3">
                <label>Facilities (comma separated)</label>
                <input asp-for="Room.facilities" class="form-control"
                       placeholder="WiFi, TV, Air Conditioner">
				<span asp-validation-for="Room.facilities" class="text-danger"></span>
            </div>

            <!-- Status -->
            <div class="mb-3">
                <label>Status</label>
                <select asp-for="Room.status" class="form-control">
                    <option>Available</option>
                    <option>Booked</option>
                    <option>Maintenance</option>
                </select>
				<span asp-validation-for="Room.status" class="text-danger"></span>
            </div>

            <!-- Image -->
            <div class="mb-3">
                <label>Room Image</label>
                <input type="file" name="Upload" class="form-control">
				<span asp-validation-for="Upload" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100" onclick="console.log('CLICKED')">
                Add Room
            </button>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="card border-danger mb-3">
                    <div class="card-header bg-danger text-white">
                        ⚠️ Validation Errors
                    </div>
                    <div class="card-body">
                        <ul class="mb-0">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <li class="text-danger">@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            }

        </form>

    </div>

</div>

<script>
    console.log("SCRIPT RUNNING");
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelector("form").addEventListener("submit", function () {
            console.log("FORM SUBMITTED");
        });
    });
</script>