@page
@model HotelManagement.Pages.Admin.ManageHotelsModel
@{
    Layout = "_AdminLayout";
}

<div class="container-fluid">

    <h2 class="mb-4">Manage Hotels</h2>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">Dashboard</li>
            <li class="breadcrumb-item">Hotels</li>
            <li class="breadcrumb-item active">Manage Hotels</li>
        </ol>
    </nav>

    <!-- Search + Add -->
    <div class="row mb-3">

        <div class="col-md-6">
            <input type="text" class="form-control" placeholder="Search hotel...">
        </div>

        <div class="col-md-6 text-end">
            <a href="/Admin/AddHotel" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Hotel
            </a>
        </div>

    </div>

    <!-- Hotel Table -->
    <div class="card">

        <div class="card-body table-responsive">

            <table class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Hotel Name</th>
                        <th>Location</th>
                        <th>Description</th>
                        <th style="width:150px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>1</td>
                        <td>Hilton</td>
                        <td>London</td>
                        <td>Luxury hotel</td>
                        <td>

                            <button class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    onclick="return confirm('Are you sure you want to delete this hotel?')">
                                <i class="fas fa-trash"></i>
                            </button>

                        </td>
                    </tr>

                    <tr>
                        <td>2</td>
                        <td>Marriott</td>
                        <td>Paris</td>
                        <td>Business hotel</td>
                        <td>

                            <button class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    onclick="return confirm('Are you sure you want to delete this hotel?')">
                                <i class="fas fa-trash"></i>
                            </button>

                        </td>
                    </tr>

                    <tr>
                        <td>3</td>
                        <td>Sheraton</td>
                        <td>Tokyo</td>
                        <td>Premium hotel</td>
                        <td>

                            <button class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    onclick="return confirm('Are you sure you want to delete this hotel?')">
                                <i class="fas fa-trash"></i>
                            </button>

                        </td>
                    </tr>

                </tbody>

            </table>

            <!-- Pagination -->
            <div class="d-flex justify-content-end mt-3">
                <nav>
                    <ul class="pagination">
                        <li class="page-item"><a class="page-link" href="#">Previous</a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item"><a class="page-link" href="#">Next</a></li>
                    </ul>
                </nav>
            </div>

        </div>

    </div>

</div>