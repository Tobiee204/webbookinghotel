@page "{id:int}"
@model HotelManagement.Pages.HotelDetailsModel

<section class="container py-5">

    <div class="row">

        <!-- Room Image -->
        <div class="col-md-6">

            <img src="@(string.IsNullOrEmpty(Model.Room.image) ? "/images/default.jpg" : Model.Room.image)"
                 class="img-fluid rounded shadow">

        </div>

        <!-- Room Info -->
        <div class="col-md-6">

            <h2>@Model.Room.title</h2>

            <p class="text-muted">
                @Model.Room.room_type
            </p>

            <h4 class="text-primary">
                @Model.Room.price VNĐ / day
            </h4>

            <p class="mt-3">
                @Model.Room.description
            </p>

            <h5 class="mt-4">Room Facilities</h5>

            <ul>
                @foreach (var f in Model.FacilitiesList)
                {
                    <li>@f</li>
                }
            </ul>

            <a asp-page="/BookRoom" asp-route-id="@Model.Room.room_id" class="btn btn-primary btn-lg">
                Book This Room
            </a>

        </div>

    </div>

</section>