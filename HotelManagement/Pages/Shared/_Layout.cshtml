<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HotelManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HotelManagement.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Header Navigation Colors */
        :root {
            --light-beige: #F5F1ED;
            --gold-accent: #C6A96D;
     --gold-dark: #A68B5B;
     --dark-text: #333;
    }

        .navbar-custom {
 background-color: var(--light-beige) !important;
      box-shadow: 0 2px 8px rgba(198, 169, 109, 0.15);
       border-bottom: 3px solid var(--gold-accent);
  }

      .navbar-custom .navbar-brand {
            color: var(--gold-accent) !important;
  font-weight: 700;
            font-size: 1.5rem;
   letter-spacing: 0.5px;
  }

        .navbar-custom .navbar-brand:hover {
            color: var(--gold-dark) !important;
      }

        .navbar-custom .nav-link {
            color: var(--dark-text) !important;
            font-weight: 500;
         transition: all 0.3s ease;
         margin: 0 8px;
}

  .navbar-custom .nav-link:hover {
  color: var(--gold-accent) !important;
        }

        .navbar-custom .navbar-toggler {
    border-color: var(--gold-accent);
        }

        .navbar-custom .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%23C6A96D' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        .btn-booking {
        background-color: var(--gold-accent) !important;
         color: white !important;
  border-color: var(--gold-accent) !important;
 font-weight: 600;
            transition: all 0.3s ease;
 }

        .btn-booking:hover {
   background-color: var(--gold-dark) !important;
    border-color: var(--gold-dark) !important;
transform: translateY(-2px);
 box-shadow: 0 4px 12px rgba(198, 169, 109, 0.3);
        }

        .btn-login {
       color: var(--dark-text) !important;
 font-weight: 500;
            transition: all 0.3s ease;
        }

   .btn-login:hover {
     color: var(--gold-accent) !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom">
<div class="container">

         <a class="navbar-brand" asp-page="/Index">Angel Hotel</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
    </button>

        <div class="collapse navbar-collapse" id="navbarNav">

         <ul class="navbar-nav me-auto">

          <li class="nav-item">
    <a class="nav-link" asp-page="/Index">Home</a>
    </li>

    <li class="nav-item">
         <a class="nav-link" asp-page="/Hotels">Rooms</a>
                 </li>

      <li class="nav-item">
             <a class="nav-link" href="#offers">Special Offers</a>
       </li>

  <li class="nav-item">
     <a class="nav-link" href="#services">Services</a>
      </li>

          <li class="nav-item">
    <a class="nav-link" href="#reviews">Reviews</a>
     </li>

     <li class="nav-item">
                <a class="nav-link" href="#contact">Contact</a>
      </li>

       </ul>

            <ul class="navbar-nav ms-auto">

         <li class="nav-item">
 <a class="nav-link btn-login" asp-page="/Profile">Account</a>
              </li>

            <li class="nav-item">
  <a class="nav-link btn-login" asp-page="/Login">Login</a>
     </li>

         </ul>

      </div>
</div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
    @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white py-4">

        <div class="container text-center">

    <p>© 2026 Hotel Booking System</p>

            <p>
         About | Contact | Privacy Policy
            </p>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
  <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>