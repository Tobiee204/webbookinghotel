<style>

    .hero-section {
        position: relative;
        height: 550px;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.45);
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .search-box {
        max-width: 850px;
        margin: auto;
    }

        .search-box select,
        .search-box input {
            height: 45px;
        }

    /* Animation */

    .animate-title {
        animation: fadeDown 1s ease;
    }

    .animate-subtitle {
        animation: fadeDown 1.5s ease;
    }

    .animate-search {
        animation: fadeUp 1.5s ease;
    }

    /* Keyframes */

    @@keyframes fadeDown {
        from

    {
        opacity: 0;
        transform: translateY(-30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    @@keyframes fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(40px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .hero-section {
        position: relative;
        height: 550px;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        transition: opacity 1.5s ease-in-out;
    }

    .hero-bg1 {
        z-index: 1;
    }

    .hero-bg2 {
        z-index: 2;
        opacity: 0;
    }

    .hero-overlay {
        position: absolute;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.45);
        z-index: 3;
    }

    .hero-content {
        position: relative;
        z-index: 4;
    }

    .search-box {
        max-width: 850px;
        margin: auto;
    }

    .room-card {
        padding: 15px;
        border-radius: 10px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .room-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

    .why-card {
        background: #000;
        color: white;
        padding: 30px;
        border-radius: 10px;
        height: 100%;
    }

        .why-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

    .service-card {
        border-radius: 12px;
        background: white;
        transition: all 0.3s ease;
    }

        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }

    /* Soft section */

    .section-soft {
        background: #f8f9fb;
    }

    /* Light section */

    .section-light {
        background: #eef2f7;
    }

    .card {
        border: none;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

    .card-img-top {
        height: 220px;
        object-fit: cover;
    }

</style>

<script>

       const images = [
    "https://images.unsplash.com/photo-1551882547-ff40c63fe5fa",
    "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4",
    "https://images.unsplash.com/photo-1566073771259-6a8506099945",
    "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb"
    ];

    let index = 0;

    const bg1 = document.querySelector(".hero-bg1");
    const bg2 = document.querySelector(".hero-bg2");

    bg1.style.backgroundImage = "url('" + images[0] + "')";

    function changeHero(){

        index++;

        if(index >= images.length){
            index = 0;
        }

        bg2.style.backgroundImage = "url('" + images[index] + "')";
        bg2.style.opacity = 1;

        setTimeout(()=>{
            bg1.style.backgroundImage = bg2.style.backgroundImage;
            bg2.style.opacity = 0;
        },1500);
    }

    setInterval(changeHero,5000);

        function searchRoom(){

        let destination = document.querySelector("input[placeholder='Destination']").value;

        if(destination.trim() !== ""){
            window.location.href = "/Hotels?room=" + destination;
        }else{
            window.location.href = "/Hotels";
        }

    }

</script>