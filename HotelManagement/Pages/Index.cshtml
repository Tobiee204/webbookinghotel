                    </a>

                </div>

            </div>

        </div>


        <div class="col-md-4">

            <div class="card shadow">

                <img src="/images/Standard.png" class="card-img-top">

                <div class="card-body text-center">

                    <h5 class="card-title">Standard Room</h5>

                    <p class="text-muted">Ho Chi Minh City</p>

