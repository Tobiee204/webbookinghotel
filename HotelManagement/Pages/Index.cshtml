@page
@model IndexModel


<!-- HERO SECTION -->
<section class="hero-section">

    <div class="hero-bg hero-bg1"></div>
    <div class="hero-bg hero-bg2"></div>

    <div class="hero-overlay"></div>

    <div class="hero-content container text-center text-white">

        <h1 class="display-4 fw-bold animate-title">
            Find Your Perfect Hotel
        </h1>

        <p class="lead animate-subtitle">
            Book your hotel room at the best price
        </p>

        <div class="search-box p-4 bg-white rounded shadow-lg animate-search">

            <div class="row g-2">

                <!-- Destination -->
                <div class="col-md-3">
                    <input type="text" class="form-control" placeholder="Destination">
                </div>

                <!-- Check In -->
                <div class="col-md-2">
                    <input type="date" class="form-control">
                </div>

                <!-- Check Out -->
                <div class="col-md-2">
                    <input type="date" class="form-control">
                </div>

                <!-- Guests -->
                <div class="col-md-2">
                    <select class="form-select">
                        <option selected disabled hidden>Guests</option>
                        <option>1 Person</option>
                        <option>2 People</option>
                        <option>3 People</option>
                        <option>4 People (Family)</option>
                    </select>
                </div>

                <!-- Bed Type -->
                <div class="col-md-2">
                    <select class="form-select">
                        <option selected disabled hidden>Bed Type</option>
                        <option>Single Bed</option>
                        <option>Double Bed</option>
                        <option>Couples Bed</option>
                        <option>Queen Bed</option>
                        <option>King Bed</option>
                    </select>
                </div>

                <!-- Search Button -->
                <div class="col-md-1">
                    <button onclick="searchRoom()" class="btn btn-primary w-200">
                        Search
                    </button>
                </div>

            </div>

        </div>

    </div>

</section>

<!-- POPULAR HOTELS -->
